<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="PanelNester"
    Manufacturer="PanelNester"
    Version="$(var.ProductVersion)"
    UpgradeCode="d84669ee-889f-45a3-9d57-fd3c0b200dd2"
    Language="1033"
    InstallerVersion="500"
    Scope="perUser"
    Compressed="yes">
    <MajorUpgrade DowngradeErrorMessage="A newer version of PanelNester is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Icon Id="PanelNesterAppIcon" SourceFile="..\..\src\PanelNester.Desktop\Assets\PanelNester.ico" />
    <Property Id="ARPPRODUCTICON" Value="PanelNesterAppIcon" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="LocalAppProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="PanelNester" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="PanelNester" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="PanelNester" Level="1">
      <ComponentGroupRef Id="AppPayload" />
      <ComponentGroupRef Id="StartMenuShortcutGroup" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="AppPayload" Directory="INSTALLFOLDER">
      <Files Include="$(var.DesktopPublishDir)**" />
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="StartMenuShortcutGroup">
      <Component Id="StartMenuShortcutComponent" Directory="ApplicationProgramsFolder" Guid="2fb8d711-b933-4b16-84c8-f54124056585">
        <Shortcut
          Id="PanelNesterStartMenuShortcut"
          Name="PanelNester"
          Description="Launch PanelNester"
          Icon="PanelNesterAppIcon"
          Target="[INSTALLFOLDER]PanelNester.Desktop.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue
          Root="HKCU"
          Key="Software\PanelNester"
          Name="StartMenuShortcutInstalled"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
