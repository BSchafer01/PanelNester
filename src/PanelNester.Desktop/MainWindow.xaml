<Window x:Class="PanelNester.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Untitled Project — PanelNester"
        Icon="Assets\PanelNester.ico"
        Height="900"
        Width="1440"
        MinHeight="640"
        MinWidth="960"
        Background="#1E1E1E"
        BorderBrush="#2D2D30"
        BorderThickness="1"
        ResizeMode="CanResize"
        WindowStyle="None"
        StateChanged="Window_StateChanged"
        Loaded="Window_Loaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="ShellTitleBarBrush" Color="#181818" />
        <SolidColorBrush x:Key="ShellChromeBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="ShellElevatedBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="ShellHoverBrush" Color="#2A2D2E" />
        <SolidColorBrush x:Key="ShellCloseHoverBrush" Color="#C42B1C" />
        <SolidColorBrush x:Key="ShellBorderBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="ShellPrimaryTextBrush" Color="#CCCCCC" />
        <SolidColorBrush x:Key="ShellSecondaryTextBrush" Color="#9D9D9D" />
        <SolidColorBrush x:Key="ShellAccentBrush" Color="#007ACC" />

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource ShellPrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{StaticResource ShellHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{StaticResource ShellElevatedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="CloseTitleBarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ShellCloseHoverBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource ShellBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ShellTitleBarBrush}"
                BorderBrush="{StaticResource ShellBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Margin="12,0,0,0"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Image Width="16"
                           Height="16"
                           VerticalAlignment="Center"
                           Source="{Binding Icon, RelativeSource={RelativeSource AncestorType=Window}}" />

                    <TextBlock x:Name="WindowTitleTextBlock"
                               Grid.Column="1"
                               Margin="8,0,24,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource ShellPrimaryTextBrush}"
                               FontSize="12"
                               Text="Untitled Project — PanelNester"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Click="MinimizeButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            ToolTip="Minimize">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Text="&#xE921;" />
                    </Button>
                    <Button x:Name="MaximizeRestoreButton"
                            Click="MaximizeRestoreButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            ToolTip="Maximize">
                        <TextBlock x:Name="WindowStateToggleGlyph"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Text="&#xE922;" />
                    </Button>
                    <Button Click="CloseButton_Click"
                            Style="{StaticResource CloseTitleBarButtonStyle}"
                            ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Text="&#xE8BB;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ShellContentHost"
              Grid.Row="1">
            <wv2:WebView2 x:Name="ShellWebView" />

            <Border x:Name="HostErrorOverlay"
                    Padding="32"
                    Background="#E01E1E1E"
                    Visibility="Collapsed">
                <StackPanel MaxWidth="720"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#F3F3F3"
                               Text="Desktop host unavailable" />
                    <TextBlock x:Name="HostErrorTextBlock"
                               Margin="0,12,0,0"
                               FontSize="14"
                               Foreground="{StaticResource ShellPrimaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
